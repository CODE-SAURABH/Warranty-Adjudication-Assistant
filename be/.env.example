APP_NAME=Warranty Adjudication Backend
APP_VERSION=1.0.0
OPENAI_API_KIND=chat_completions
OPENAI_API_BASE=https://llm-proxy.kpit.com/v1
OPENAI_MODEL=kgpt-reasoning-text
OPENAI_API_KEY=replace-me

# Local SQLite by default
DB_BACKEND=local
LOCAL_DB_PATH=./data/warranty.db
DB_SEED_ON_STARTUP=true
DB_ECHO=false
DB_AUTO_CREATE_SCHEMA=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
POLICY_UPLOAD_DIR=./data/policy_corpus
POLICY_MAX_UPLOAD_MB=15
# For Postgres, switch DB_BACKEND to postgres and replace placeholders below.
# DATABASE_URL=postgresql+psycopg://<USERNAME>:<PASSWORD>@<HOST>:<PORT>/<DATABASE_NAME>
# DATABASE_URL=postgresql+psycopg://admin:admin123@localhost:5432/warrantyIQ
#
# DB_BACKEND=postgres
# DATABASE_URL=postgresql+psycopg://<USERNAME>:<PASSWORD>@<HOST>:<PORT>/<DATABASE_NAME>
# DB_AUTO_CREATE_SCHEMA=false
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com,http://localhost:5173
# POLICY_UPLOAD_DIR=./data/policy_corpus
# POLICY_MAX_UPLOAD_MB=15
#
# Or leave DATABASE_URL commented and use these values instead:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=admin
# POSTGRES_PASSWORD=admin123
# POSTGRES_DB=warrantyIQ
